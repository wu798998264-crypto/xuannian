{
  "name": "xuannian",
  "version": "4.0.0",
  "description": "玄念本地剪切板、便签与灵感工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/build.js portable",
    "dist:installer": "node scripts/build.js nsis",
    "dist:all": "node scripts/build.js portable nsis"
  },
  "build": {
    "appId": "app.xuannian.desktop.rounded",
    "productName": "玄念4.0",
    "compression": "maximum",
    "asar": true,
    "afterPack": "scripts/afterPack.js",
    "electronLanguages": [
      "zh-CN"
    ],
    "files": [
      "index.html",
      "quick.html",
      "sticky.html",
      "screenshot-select.html",
      "src/**/*",
      "!src/native/*.cs",
      "!src/xuannian-logo.png",
      "package.json"
    ],
    "asarUnpack": [
      "src/native/XuanNianClipboardHelper.exe"
    ],
    "extraResources": [
      {
        "from": "src/native/XuanNianClipboardHelper.exe",
        "to": "native/XuanNianClipboardHelper.exe"
      }
    ],
    "win": {
      "icon": "src/xuannian-logo.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "unpackDirName": false,
      "artifactName": "玄念4.0-便携版.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "artifactName": "玄念4.0-安装包.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}
