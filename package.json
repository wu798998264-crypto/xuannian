{
  "name": "xuannian",
  "version": "6.1.5",
  "description": "玄念本地剪切板、收藏与置顶便签工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/build.js portable",
    "dist:installer": "node scripts/build.js nsis",
    "dist:all": "node scripts/build.js portable nsis"
  },
  "build": {
    "appId": "app.xuannian.desktop",
    "productName": "玄念",
    "compression": "maximum",
    "asar": true,
    "disableAsarIntegrity": true,
    "afterPack": "scripts/afterPack.js",
    "electronLanguages": [
      "zh-CN"
    ],
    "files": [
      "index.html",
      "quick.html",
      "sticky.html",
      "screenshot-select.html",
      "src/**/*",
      "!src/native/*.cs",
      "!src/native/XuanNianClipboardHelper.exe",
      "!src/xuannian-logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/native/XuanNianClipboardHelper.exe",
        "to": "native/XuanNianClipboardHelper.exe"
      }
    ],
    "win": {
      "icon": "src/xuannian-logo.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "unpackDirName": false,
      "artifactName": "XuanNian-${version}-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "artifactName": "XuanNian-${version}-Setup.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wu798998264-crypto",
        "repo": "xuannian",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
